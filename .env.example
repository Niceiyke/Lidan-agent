# Agentic OS Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Database (PostgreSQL)
# ============================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://agentic:agentic_dev@localhost:5432/agentic_os

# ============================================
# Redis (for BullMQ queue)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ============================================
# Server
# ============================================
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ============================================
# Workspaces (where project files are stored)
# ============================================
WORKSPACES_PATH=/tmp/agentic-workspaces

# ============================================
# AI Provider API Keys (at least one required)
# ============================================
# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4)
OPENAI_API_KEY=sk-...

# Or use Pi login: `pi /login` in your terminal

# ============================================
# Worker Configuration
# ============================================
# Maximum concurrent tasks
MAX_CONCURRENT_TASKS=5

# Execution timeout in seconds
EXECUTION_TIMEOUT=300

# ============================================
# Docker
# ============================================
# Docker host (for DinD)
DOCKER_HOST=unix:///var/run/docker.sock

# ============================================
# Agentic OS API URL (for extensions)
# ============================================
AGENTIC_API_URL=http://localhost:3001
